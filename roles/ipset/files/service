[Unit]
Description=ipset load service
After=network.target

# Run before iptables loads.
# Iptables rules that reference missing ipsets
# makes all rules fail to load.
Before=netfilter-persistent.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash /opt/ipset/load.bash
ExecReload=/bin/bash /opt/ipset/load.bash
SyslogIdentifier=ipset-load

[Install]
WantedBy=multi-user.target
