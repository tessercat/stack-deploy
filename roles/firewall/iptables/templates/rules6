# Chains.
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Implement a default deny policy.
-P INPUT DROP
-P FORWARD DROP

# Accept loopback traffic.
-A INPUT -i lo -j ACCEPT

# Accept all ICMP traffic.
-A INPUT -p ipv6-icmp -j ACCEPT

# Drop traffic from addresses in the block6 ipset.
-A INPUT -m set --match-set block6 src -j ACCEPT

# Be stateful.
-A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# Accept all SSH traffic.
-A INPUT -p tcp -m tcp --dport {{ ssh_port }} -j ACCEPT

# Accept web traffic.
-A INPUT -p tcp -m tcp --dport 80 -j ACCEPT
-A INPUT -p tcp -m tcp --dport 443 -j ACCEPT

# And finally.
COMMIT
